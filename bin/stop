#!/bin/bash

# PicoClaw Docker Stop Script
# Stops the running PicoClaw container

set -e

CONTAINER_NAME="picoclaw-gateway"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

echo -e "${BLUE}🛑 PicoClaw Docker Stop${NC}"
echo "================================"

# Check if container is running
if docker ps --format "{{.Names}}" | grep -q "^${CONTAINER_NAME}$"; then
    echo -e "${YELLOW}⚠${NC} Stopping $CONTAINER_NAME..."
    docker stop "$CONTAINER_NAME" > /dev/null 2>&1
    echo -e "${GREEN}✓${NC} Container stopped"
    
    # Remove the container
    docker rm "$CONTAINER_NAME" > /dev/null 2>&1
    echo -e "${GREEN}✓${NC} Container removed"
else
    echo -e "${YELLOW}⚠${NC} Container $CONTAINER_NAME is not running"
fi

echo ""
echo -e "${GREEN}🦞 PicoClaw has been stopped${NC}"
