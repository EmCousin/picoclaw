#!/bin/bash

# PicoClaw Docker Startup Script
# Boots PicoClaw via Docker with browser automation support

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
DOCKERFILE="$PROJECT_ROOT/docker/Dockerfile.debian"
IMAGE_NAME="picoclaw:debian"
CONTAINER_NAME="picoclaw-gateway"
DATA_DIR="$PROJECT_ROOT/docker/data"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

echo -e "${BLUE}🦞 PicoClaw Docker Starter${NC}"
echo "================================"

# Check if Docker is running
if ! docker info > /dev/null 2>&1; then
    echo -e "${RED}❌ Error: Docker is not running${NC}"
    echo "Please start Docker and try again."
    exit 1
fi

echo -e "${GREEN}✓${NC} Docker is running"

# Check if image exists, build if not
if ! docker images --format "{{.Repository}}:{{.Tag}}" | grep -q "^${IMAGE_NAME}$"; then
    echo -e "${YELLOW}⚠${NC} PicoClaw image not found, building..."
    echo "This may take a few minutes..."
    docker build -f "$DOCKERFILE" -t "$IMAGE_NAME" "$PROJECT_ROOT"
    echo -e "${GREEN}✓${NC} Build complete"
else
    echo -e "${GREEN}✓${NC} Using existing image: $IMAGE_NAME"
fi

# Ensure data directory exists
mkdir -p "$DATA_DIR"

# Initialize config if first run
if [ ! -f "$DATA_DIR/config.json" ]; then
    echo -e "${YELLOW}⚠${NC} First run detected, initializing config..."
    docker run --rm \
        -v "$DATA_DIR:/home/picoclaw/.picoclaw" \
        "$IMAGE_NAME" onboard
    echo -e "${GREEN}✓${NC} Config initialized at: $DATA_DIR/config.json"
    echo ""
    echo -e "${YELLOW}⚠ IMPORTANT:${NC} Please edit $DATA_DIR/config.json to add your API keys"
    echo "   Get your API key from: https://openrouter.ai/keys"
    echo ""
fi

# Stop existing container if running
if docker ps --format "{{.Names}}" | grep -q "^${CONTAINER_NAME}$"; then
    echo -e "${YELLOW}⚠${NC} Stopping existing container..."
    docker stop "$CONTAINER_NAME" > /dev/null 2>&1
    echo -e "${GREEN}✓${NC} Stopped existing container"
fi

# Remove existing container if exists
if docker ps -a --format "{{.Names}}" | grep -q "^${CONTAINER_NAME}$"; then
    docker rm "$CONTAINER_NAME" > /dev/null 2>&1
fi

echo ""
echo -e "${BLUE}🚀 Starting PicoClaw Gateway...${NC}"
echo ""

# Run PicoClaw Gateway
docker run -d \
    --name "$CONTAINER_NAME" \
    -v "$DATA_DIR:/home/picoclaw/.picoclaw" \
    -e PICOCLAW_TOOLS_BROWSER_ENABLED=true \
    -e PICOCLAW_HOME=/home/picoclaw/.picoclaw \
    -e PATH="/home/picoclaw/.cargo/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin" \
    -p 18790:18790 \
    --restart unless-stopped \
    "$IMAGE_NAME" \
    gateway

echo -e "${GREEN}✓${NC} PicoClaw Gateway started!"
echo ""
echo -e "${BLUE}📊 Container Status:${NC}"
docker ps --filter "name=$CONTAINER_NAME" --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"
echo ""
echo -e "${BLUE}📋 Useful Commands:${NC}"
echo "  View logs:     docker logs -f $CONTAINER_NAME"
echo "  Stop:          docker stop $CONTAINER_NAME"
echo "  Restart:       docker restart $CONTAINER_NAME"
echo "  Shell access:  docker exec -it $CONTAINER_NAME /bin/bash"
echo ""
echo -e "${BLUE}🔗 Health Check:${NC}"
echo "  curl http://localhost:18790/health"
echo ""
echo -e "${GREEN}🦞 PicoClaw is ready!${NC}"
